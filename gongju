            <path d="M -10,-10 C -4,-4 -4,4 -10,10" stroke="#dc2626" stroke-width="1.5" fill="none" stroke-dasharray="2,2" />
            <path d="M 10,-10 C 4,-4 4,4 10,10" stroke="#dc2626" stroke-width="1.5" fill="none" stroke-dasharray="2,2" />
          </g>
        </g>
      </svg>
    `;

    // ==========================================
    // STADIUM GEOGRAPHIC DATA
    // ==========================================
    const STADIUM_DATA = [
      { name: '공주중학교 야구장', address: '충청남도 공주시 봉황로 125', link: 'https://naver.me/5JqDo0PX' },
      { name: '공주 천변구장', address: '충남 공주시 쌍신동 둔치 야구장', link: 'https://naver.me/5hoKhlRO' },
      { name: '박찬호 시립야구장', address: '충청남도 공주시 쌍신동 416', link: 'https://naver.me/x3jVe6H0' },
      { name: '공주고등학교 야구장', address: '충청남도 공주시 중동 171', link: 'https://naver.me/x52ZgxaZ' }
    ];

    // ==========================================
    // STATE VARIABLES (Vanilla JS)
    // ==========================================
    let currentLeague = '새싹';
    let currentDate = '전체';
    let isStadiumPanelVisible = false;

    // Injected elements
    document.getElementById('header-logo').innerHTML = LOGO_SVG;

    // Toast Generator
    function showToast(message) {
      const toastEl = document.getElementById('toast');
      const messageEl = document.getElementById('toast-message');
      messageEl.textContent = message;
      toastEl.classList.remove('hidden');
      setTimeout(() => {
        toastEl.classList.add('hidden');
      }, 4000);
    }

    // Toggle Stadium Folder
    function toggleStadiumPanel(shouldShow) {
      const panel = document.getElementById('stadium-panel');
      const descText = document.getElementById('stat-stadium-desc');
      const card = document.getElementById('stat-stadium');
      
      isStadiumPanelVisible = shouldShow;
      
      if (isStadiumPanelVisible) {
        panel.classList.remove('hidden');
        descText.textContent = '구장 패널 숨기기';
        card.className = "rounded-2xl p-4 text-center border transition-all duration-300 transform hover:scale-[1.03] shadow-md bg-slate-900 text-white border-slate-950 ring-4 ring-slate-800/20";
      } else {
        panel.classList.add('hidden');
        descText.textContent = '클릭 시 구장정보 열기';
        card.className = "rounded-2xl p-4 text-center border transition-all duration-300 transform hover:scale-[1.03] shadow-md bg-white text-slate-800 border-slate-200/80 hover:bg-slate-50";
      }
    }

    // Handler for Statistics Cards click
    function handleStatCardClick(type) {
      if (type === '새싹' || type === '꿈나무' || type === '유소년') {
        filterLeague(type);
        toggleStadiumPanel(false);
        showToast(`🌱 ${type} 리그 경기 일정으로 자동 전환 및 필터링되었습니다.`);
      } else if (type === '구장') {
        toggleStadiumPanel(!isStadiumPanelVisible);
        showToast(`🏟️ 공주대회 공식 경기장 정보 패널이 ${isStadiumPanelVisible ? '활성화' : '닫힘'}되었습니다.`);
      }
    }

    // Render Stadium Information Dynamic Grid
    function renderStadiums() {
      const container = document.querySelector('#stadium-panel .grid');
      container.innerHTML = STADIUM_DATA.map((stadium, index) => `
        <div class="bg-slate-50 border border-slate-150 rounded-2xl p-4 flex flex-col justify-between hover:border-slate-300 hover:shadow-xs transition-all">
          <div>
            <h4 class="font-extrabold text-sm text-slate-900 flex items-center gap-1">
              <span class="text-[11px] bg-slate-200 px-1.5 py-0.5 rounded text-slate-600 font-bold font-mono">${index + 1}</span>
              ${stadium.name}
            </h4>
            <p class="text-xs text-slate-500 mt-2 font-medium leading-relaxed">${stadium.address}</p>
          </div>
          <button 
            onclick="handleMapOpen(event, '${stadium.link}', '${stadium.name}')"
            class="mt-4 w-full py-2 bg-green-600 hover:bg-green-700 text-white font-black text-xs rounded-xl transition-all shadow-sm flex items-center justify-center gap-1"
          >
            🧭 네이버 지도로 보기
          </button>
        </div>
      `).join('');
    }

    // Interactive Iframe-safe Map Open Handler
    function handleMapOpen(e, url, stadiumName) {
      if (e) e.preventDefault();
      const newWindow = window.open(url, '_blank', 'noopener,noreferrer');
      if (!newWindow || newWindow.closed || typeof newWindow.closed === 'undefined') {
        showToast(`📌 브라우저 보안으로 새 창이 막혔습니다. 아래 주소 링크로 이동해 주세요!\n[링크: ${url}]`);
      } else {
        showToast(`🗺️ ${stadiumName} 네이버 지도 공식 링크로 안전하게 연동되었습니다!`);
      }
    }

    // Date Filter Implementation
    function filterDate(dateStr) {
      currentDate = dateStr;
      
      // Update toggle button states (대형화 최적화 일치)
      const dates = { '전체': 'btn-date-all', '2026-06-20': 'btn-date-20', '2026-06-21': 'btn-date-21' };
      Object.keys(dates).forEach(key => {
        const btn = document.getElementById(dates[key]);
        if (key === currentDate) {
          btn.className = "flex-1 sm:flex-initial px-4 py-2.5 sm:py-2 rounded-xl transition-all text-center text-xs sm:text-sm md:text-base bg-white text-slate-950 shadow-sm font-black whitespace-nowrap";
        } else {
          btn.className = "flex-1 sm:flex-initial px-4 py-2.5 sm:py-2 rounded-xl transition-all text-center text-xs sm:text-sm md:text-base text-slate-600 hover:text-slate-800 whitespace-nowrap";
        }
      });

      renderScheduleList();
    }

    // League Filter Implementation
    function filterLeague(leagueStr) {
      currentLeague = leagueStr;

      // Update Tab bar states
      const tabs = { '새싹': 'tab-sprout', '꿈나무': 'tab-dream', '유소년': 'tab-youth', '전체': 'tab-all' };
      Object.keys(tabs).forEach(key => {
        const btn = document.getElementById(tabs[key]);
        if (key === currentLeague) {
          btn.className = "px-3.5 py-2.5 text-xs sm:text-sm rounded-xl border transition-all whitespace-nowrap shrink-0 border-slate-900 text-white font-black bg-slate-900";
        } else {
          btn.className = "px-3.5 py-2.5 text-xs sm:text-sm rounded-xl border transition-all whitespace-nowrap shrink-0 border-slate-200 text-slate-500 hover:bg-slate-50 bg-white";
        }
      });

      // Update Quick Statistic Highlight ring (색상 깨짐 & 가독성 버그 완전 해결)
      const statIds = { '새싹': 'stat-sprout', '꿈나무': 'stat-dream', '유소년': 'stat-youth' };
      Object.keys(statIds).forEach(key => {
        const card = document.getElementById(statIds[key]);
        const desc = document.getElementById(`${statIds[key]}-desc`);
        if (key === currentLeague && !isStadiumPanelVisible) {
          if (key === '새싹') {
            card.className = "rounded-2xl p-4 text-center border transition-all duration-300 transform hover:scale-[1.03] shadow-md bg-emerald-600 text-white border-emerald-700 ring-4 ring-emerald-500/20";
            if (desc) desc.className = "text-[10px] mt-1 font-bold text-emerald-100";
          }
          if (key === '꿈나무') {
            card.className = "rounded-2xl p-4 text-center border transition-all duration-300 transform hover:scale-[1.03] shadow-md bg-blue-600 text-white border-blue-700 ring-4 ring-blue-500/20";
            if (desc) desc.className = "text-[10px] mt-1 font-bold text-blue-100";
          }
          if (key === '유소년') {
            card.className = "rounded-2xl p-4 text-center border transition-all duration-300 transform hover:scale-[1.03] shadow-md bg-amber-600 text-white border-amber-700 ring-4 ring-amber-500/20";
            if (desc) desc.className = "text-[10px] mt-1 font-bold text-amber-100";
          }
        } else {
          if (key === '새싹') {
            card.className = "rounded-2xl p-4 text-center border transition-all duration-300 transform hover:scale-[1.03] shadow-md bg-white text-emerald-600 border-slate-200/80 hover:bg-slate-50";
            if (desc) desc.className = "text-[10px] mt-1 font-bold text-slate-400";
          }
          if (key === '꿈나무') {
            card.className = "rounded-2xl p-4 text-center border transition-all duration-300 transform hover:scale-[1.03] shadow-md bg-white text-blue-600 border-slate-200/80 hover:bg-slate-50";
            if (desc) desc.className = "text-[10px] mt-1 font-bold text-slate-400";
          }
          if (key === '유소년') {
            card.className = "rounded-2xl p-4 text-center border transition-all duration-300 transform hover:scale-[1.03] shadow-md bg-white text-amber-500 border-slate-200/80 hover:bg-slate-50";
            if (desc) desc.className = "text-[10px] mt-1 font-bold text-slate-400";
          }
        }
      });

      renderScheduleList();
    }

    // Dynamic Team Badge Renderer
    function getTeamBadgeHtml(teamName) {
      if (teamName === '화정') {
        return `
          <span class="inline-flex items-center gap-1.5 bg-emerald-50 text-emerald-900 px-2.5 py-1 rounded-full border border-emerald-100 text-xs sm:text-sm font-black shadow-3xs shrink-0 max-w-full">
            <span class="relative w-5 h-5 rounded-md overflow-hidden border border-amber-500 bg-white inline-flex items-center justify-center shrink-0">
              ${LOGO_SVG}
            </span>
            화정
          </span>
        `;
      }
      return `<span class="text-slate-800 font-extrabold text-xs sm:text-sm md:text-base truncate">${teamName}</span>`;
    }

    // Match Schedule Grid Render Engine
    function renderScheduleList() {
      const listContainer = document.getElementById('match-list');

      const filtered = MATCH_SCHEDULE.filter(match => {
        const matchLeague = currentLeague === '전체' || match.league === currentLeague;
        const matchDate = currentDate === '전체' || match.date === currentDate;
        return matchLeague && matchDate;
      });

      if (filtered.length === 0) {
        listContainer.innerHTML = `
          <div class="py-14 text-center text-slate-400 flex flex-col items-center justify-center">
            <span class="text-4xl animate-bounce mb-2">🐯🧢</span>
            <p class="text-xs font-black text-slate-500">선택한 조건에 해당하는 경기 일정이 없습니다.</p>
            <button 
              onclick="setSelectedStateAll()" 
              class="mt-2 text-[11px] text-emerald-600 font-extrabold hover:underline"
            >
              필터 초기화하기
            </button>
          </div>
        `;
        return;
      }

      listContainer.innerHTML = filtered.map(match => {
        const borderHighlight = match.league === '새싹' ? '<div class="absolute top-0 left-0 bottom-0 w-1 bg-emerald-500"></div>' : '';
        
        return `
          <div class="relative rounded-2xl border border-slate-200 p-4 transition-all bg-white shadow-xs overflow-hidden">
            ${borderHighlight}
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
              
              <!-- LEFT: DATE TIME & TEAMS (날짜 요일 및 시간 극대화 반영) -->
              <div class="flex items-center gap-3 w-full md:w-auto">
                <div class="flex flex-col items-center justify-center bg-slate-50 border border-slate-200 rounded-xl p-2.5 min-w-[125px] sm:min-w-[145px] text-center shrink-0 shadow-3xs">
                  <span class="text-base sm:text-lg font-black text-slate-900">06월 ${match.day}일</span>
                  <span class="text-base sm:text-lg font-black text-emerald-700 mt-0.5">${match.dayOfWeek}</span>
                  
                  <!-- 시작 시간 가독성 향상 배지 (대폭 크기 증가) -->
                  <div class="mt-2.5 bg-amber-50 text-amber-950 border border-amber-200 rounded-xl px-2.5 py-1 text-xs sm:text-sm font-black font-mono flex items-center justify-center gap-1.5 shadow-2xs">
                    <span>⏰</span>
                    <span>${match.time}</span>
                  </div>
                </div>

                <div class="space-y-3 min-w-0 flex-1">
                  <div class="flex items-center gap-2 flex-wrap">
                    <span class="text-xs sm:text-sm font-black px-3 py-1 rounded-full border-2 ${match.leagueColor}">
                      ${match.league} 리그
                    </span>
                    <span class="text-slate-300 text-sm">|</span>
                    
                    <button
                      onclick="handleMapOpen(event, '${getStadiumLink(match.stadium)}', '${match.stadium}')"
                      class="text-xs sm:text-sm md:text-base font-black text-emerald-800 hover:text-white bg-emerald-50 hover:bg-emerald-600 px-3.5 py-1.5 rounded-full border-2 border-emerald-200 transition-all inline-flex items-center gap-1.5 shadow-sm"
                    >
                      🏟️ ${match.stadium} ↗
                    </button>
                  </div>

                  <div class="flex items-center gap-3.5 flex-wrap min-w-0">
                    ${getTeamBadgeHtml(match.homeTeam)}
                    <span class="text-slate-400 font-black text-sm sm:text-base md:text-xl mx-2.5 select-none shrink-0 tracking-widest">VS</span>
                    ${getTeamBadgeHtml(match.awayTeam)}
                  </div>
                </div>
              </div>

              <!-- RIGHT: WEATHER & MAP NAVIGATION -->
              <div class="flex flex-row md:flex-col items-center md:items-end justify-between md:justify-center gap-2 pt-3 md:pt-0 border-t md:border-t-0 border-slate-100 w-full md:w-auto shrink-0">
                <div class="bg-sky-50 text-sky-950 border border-sky-100 rounded-lg px-2.5 py-1 text-xs font-black flex items-center gap-1 whitespace-nowrap">
                  <span>${match.weather.icon}</span> 
                  <span>${match.weather.desc} (${match.weather.temp})</span>
                </div>
                <button 
                  onclick="handleMapOpen(event, '${getStadiumLink(match.stadium)}', '${match.stadium}')"
                  class="flex items-center justify-center gap-1 py-2 px-3.5 text-xs font-black rounded-xl bg-green-600 hover:bg-green-700 text-white transition-all shadow-xs active:scale-95 animate-pulse shrink-0"
                >
                  🧭 네이버 지도
                </button>
              </div>

            </div>
          </div>
        `;
      }).join('');
    }

    // Reset filter states
    function setSelectedStateAll() {
      currentLeague = '전체';
      currentDate = '전체';
      filterLeague('전체');
      filterDate('전체');
    }

    // ==========================================
    // INITIALIZATION RUNTIME
    // ==========================================
    window.onload = function() {
      renderStadiums();
      filterLeague('새싹'); // Default to Sprout League as requested
    };
  </script>
</body>
</html>
